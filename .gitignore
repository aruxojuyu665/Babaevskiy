# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# leads data
/data/

# large video originals (keep renamed copy)
public/video/Rotating_Sofa_Reveal*

# typescript
*.tsbuildinfo
next-env.d.ts

# original (pre-optimization) image backups — keep local, don't commit
public/**/*.orig.jpg
public/**/*.orig.jpeg
public/**/*.orig.png

# test output
playwright-report/
test-results/
.lighthouseci/
perf-reports/
.playwright-mcp/

# local screenshot baselines (regenerate via `npm run test:visual:update`)
/screenshots/
/test-screenshots/

# unrelated research artifact
compass_artifact_*.md

